---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content="Portfólio de Ana Rita de Mattos Marques — Pedagoga e especialista em educação inclusiva." />
  <title>{title}</title>
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <div class="logo">
        <span class="logo-serif">Ana Rita</span>
        <span class="logo-sans">Pedagoga</span>
      </div>
      <nav class="links" aria-label="Navegação principal">
        <a href="#sobre" class="nav-link">Trajetória</a>
        <a href="#galeria" class="nav-link">Prática</a>
        <a href="#formacao" class="nav-link">Formação</a>
        <a href="#projetos" class="btn btn-primary nav-cta">Contato</a>
      </nav>
    </div>
  </header>

  <slot />
</body>
</html>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    padding: 18px 0;
    background: color-mix(in srgb, var(--bg-primary) 94%, white);
    border-bottom: 1px solid var(--line-color);
  }

  .topbar-inner,
  .links,
  .logo {
    display: flex;
    align-items: center;
  }

  .topbar-inner {
    justify-content: space-between;
    gap: 24px;
  }

  .logo { gap: 8px; }

  .logo-serif {
    color: var(--brand-purple);
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .logo-sans {
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .links { gap: clamp(16px, 2.5vw, 32px); }

  .nav-link {
    color: var(--text-ink);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--brand-purple-light);
  }

  .nav-cta {
    padding: 10px 22px;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .topbar { padding: 14px 0; }
    .links .nav-link { display: none; }
    .logo-serif { font-size: 1.25rem; }
    .logo-sans { font-size: 0.7rem; }
  }
</style>
