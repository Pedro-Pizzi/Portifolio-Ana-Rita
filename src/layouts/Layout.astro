---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content="Portfólio de Ana Rita de Mattos Marques — Pedagoga e especialista em educação inclusiva." />
  <title>{title}</title>
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <div class="logo">
        <span class="logo-serif">Ana Rita</span>
        <span class="logo-sans">Pedagoga</span>
      </div>
      <nav class="links" aria-label="Navegação principal">
        <a href="#sobre" class="nav-link">Trajetória</a>
        <a href="#galeria" class="nav-link">Prática</a>
        <a href="#formacao" class="nav-link">Formação</a>
        <a href="#projetos" class="btn btn-primary nav-cta">Contato</a>
      </nav>
    </div>
  </header>

  <slot />

  <!-- Background SVG Blobs -->
  <svg class="ambient-glow" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
    <defs>
      <filter id="ambient-blur" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="60" />
      </filter>
      <!-- Liquid Hover Filter -->
      <filter id="liquid">
        <feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="3" result="warp" />
        <feDisplacementMap xChannelSelector="R" yChannelSelector="G" scale="30" in="SourceGraphic" in2="warp" />
      </filter>
    </defs>
    
    <g filter="url(#ambient-blur)">
      <circle cx="10vw" cy="20vh" r="30vw" fill="var(--accent-mint)" opacity="0.6">
        <animate attributeName="cx" values="10vw; 80vw; 10vw" dur="40s" repeatCount="indefinite" />
        <animate attributeName="cy" values="20vh; 60vh; 20vh" dur="50s" repeatCount="indefinite" />
      </circle>
      <circle cx="80vw" cy="70vh" r="25vw" fill="var(--accent-butter)" opacity="0.5">
        <animate attributeName="cx" values="80vw; 20vw; 80vw" dur="45s" repeatCount="indefinite" />
        <animate attributeName="cy" values="70vh; 10vh; 70vh" dur="35s" repeatCount="indefinite" />
      </circle>
    </g>
  </svg>

  <!-- Cursor Customizado HTML -->
  <div class="custom-cursor-follower" id="custom-cursor-follower" aria-hidden="true"></div>
  <div class="custom-cursor" id="custom-cursor" aria-hidden="true"></div>

  <!-- Cinematic Noise Overlay -->
  <div class="noise-overlay"></div>

  <script>
    // Cursor script (Vanilla JS & requestAnimationFrame for max performance)
    const dot = document.getElementById('custom-cursor');
    const follower = document.getElementById('custom-cursor-follower');
    
    // Check for reduced motion and touch devices to completely disable custom cursor logic
    const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouch = window.matchMedia('(pointer: coarse)').matches;

    if (dot && follower && !isReducedMotion && !isTouch) {
      let mouseX = window.innerWidth / 2;
      let mouseY = window.innerHeight / 2;
      let cursorX = mouseX;
      let cursorY = mouseY;
      let followerX = mouseX;
      let followerY = mouseY;

      window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        
        // Expose normalized mouse coordinates to CSS for 3D parallax
        const normX = (e.clientX / window.innerWidth) * 2 - 1; // -1 to 1
        const normY = (e.clientY / window.innerHeight) * 2 - 1;
        document.documentElement.style.setProperty('--mouse-x', normX);
        document.documentElement.style.setProperty('--mouse-y', normY);
        
        // Expose pixel coordinates for glass spotlight
        document.documentElement.style.setProperty('--mouse-x-px', `${e.clientX}px`);
        document.documentElement.style.setProperty('--mouse-y-px', `${e.clientY}px`);
      }, { passive: true });

      const loop = () => {
        // Fast snap for dot
        cursorX += (mouseX - cursorX) * 0.8;
        cursorY += (mouseY - cursorY) * 0.8;
        
        // Smooth LERP for follower
        followerX += (mouseX - followerX) * 0.15;
        followerY += (mouseY - followerY) * 0.15;
        
        dot.style.transform = `translate3d(${cursorX - 4}px, ${cursorY - 4}px, 0)`;
        follower.style.transform = `translate3d(${followerX - 16}px, ${followerY - 16}px, 0)`;
        
        requestAnimationFrame(loop);
      };
      
      requestAnimationFrame(loop);

      // Magnetic/Hover effect on links and buttons
      const interactiveElements = document.querySelectorAll('a, button, .interactive');
      interactiveElements.forEach(el => {
        el.addEventListener('mouseenter', () => {
          follower.classList.add('hovering');
          dot.style.opacity = '0';
        });
        el.addEventListener('mouseleave', () => {
          follower.classList.remove('hovering');
          dot.style.opacity = '1';
          el.style.transform = '';
        });
        
        // Magnetic effect if it's a button
        if(el.classList.contains('btn') || el.classList.contains('interactive')) {
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const elCenterX = rect.left + rect.width / 2;
            const elCenterY = rect.top + rect.height / 2;
            const distX = e.clientX - elCenterX;
            const distY = e.clientY - elCenterY;
            
            // Pull the button towards mouse
            el.style.transform = `translate3d(${distX * 0.2}px, ${distY * 0.2}px, 0)`;
            // Snap the follower to the button
            mouseX = elCenterX + distX * 0.1;
            mouseY = elCenterY + distY * 0.1;
          });
        }
      });
    }

    // Intersection Observer for Reveal Animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target); // Animate only once
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-up').forEach(el => {
      observer.observe(el);
    });
  </script>
</body>
</html>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    padding: 18px 0;
    background: color-mix(in srgb, var(--bg-primary) 94%, white);
    border-bottom: 1px solid var(--line-color);
  }

  .topbar-inner,
  .links,
  .logo {
    display: flex;
    align-items: center;
  }

  .topbar-inner {
    justify-content: space-between;
    gap: 24px;
  }

  .logo { gap: 8px; }

  .logo-serif {
    color: var(--brand-purple);
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .logo-sans {
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .links { gap: clamp(16px, 2.5vw, 32px); }

  .nav-link {
    color: var(--text-ink);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--brand-purple-light);
  }

  .nav-cta {
    padding: 10px 22px;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .topbar { padding: 14px 0; }
    .links .nav-link { display: none; }
    .logo-serif { font-size: 1.25rem; }
    .logo-sans { font-size: 0.7rem; }
  }
</style>
